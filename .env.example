# =============================================================================
# AIOps Orchestrator - Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- General ---
AIOPS_DEBUG=false
AIOPS_HOST=0.0.0.0
AIOPS_PORT=8000
AIOPS_LOG_LEVEL=INFO
AIOPS_LOG_FORMAT=json

# --- Authentication ---
# Shared token between WebAI and orchestrator. CHANGE THIS!
AIOPS_API_TOKEN=changeme-generate-a-secure-token

# --- Database ---
AIOPS_DATABASE_URL=sqlite+aiosqlite:///data/aiops.db

# --- Ollama (local LLM) ---
# Agent Router also accepts OLLAMA_HOST for compatibility with Open WebUI style env.
OLLAMA_HOST=http://192.168.3.87:11434
AIOPS_OLLAMA_BASE_URL=http://192.168.3.87:11434
# Benchmark winners (Apr 2026): FAST=gemma3:4b, SMART=qwen3:8b
AIOPS_OLLAMA_DEFAULT_MODEL=gemma3:4b
AIOPS_OLLAMA_FAST_MODEL=gemma3:4b
AIOPS_OLLAMA_SMART_MODEL=qwen3:8b

# --- Claude API (optional - enable for deep planning) ---
# Agent Router also accepts ANTHROPIC_API_KEY. Leave empty here; set only in real .env.
ANTHROPIC_API_KEY=
AIOPS_CLAUDE_API_KEY=
AIOPS_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI-compatible API (optional) ---
# Agent Router also accepts OPENAI_API_KEY. Leave empty here; set only in real .env.
OPENAI_API_KEY=
AIOPS_OPENAI_API_KEY=
AIOPS_OPENAI_BASE_URL=https://api.openai.com/v1
# GPT (geral, @auto) — gpt-5-nano = gpt-5.4-nano: $0.20/$1.25 por 1M tokens
# AVISO: gpt-5 usa raciocinío interno: max_completion_tokens deve ser >=4096
AIOPS_GPT_MODEL=gpt-5-nano
# Codex (explícito @codex) — gpt-4.1-nano: $0.10/$0.40 por 1M tokens (4× mais barato que mini)
AIOPS_CODEX_MODEL=gpt-4.1-nano
# Legacy — kept for backward compat
AIOPS_OPENAI_MODEL=gpt-5-nano

# --- Agent Router ---
AGENT_ROUTER_PORT=8010
AGENT_ROUTER_TIMEOUT_SECONDS=120
OLLAMA_TIMEOUT_SECONDS=60
CODEX_CLI_ENABLED=false
CODEX_COMMAND=codex
CODEX_TIMEOUT_SECONDS=180

# --- Smart @auto routing (FASE 5) ---
PROMETHEUS_URL=http://192.168.3.200:9090
# balanced (default): execution -> GPT, local for simple/complex
# local-max: execution/complex/simple prefer local models unless overload
AIOPS_ROUTING_MODE=balanced
AIOPS_CPU_HIGH_THRESHOLD=80
AIOPS_OLLAMA_LATENCY_HIGH_SECONDS=15
# Overload guardrails used only in local-max mode
AIOPS_LOCAL_MAX_CPU_HIGH_THRESHOLD=92
AIOPS_LOCAL_MAX_OLLAMA_LATENCY_HIGH_SECONDS=35

# --- Provider Routing ---
AIOPS_PLANNER_DEFAULT=claude
AIOPS_PLANNER_FALLBACK=ollama
AIOPS_CLASSIFIER_DEFAULT=ollama
AIOPS_EXECUTOR_DEFAULT=local

# --- Policy ---
# Modes: safe | supervised | manual-only
AIOPS_POLICY_MODE=supervised
AIOPS_AUTO_APPROVE_LOW_RISK=false

# --- Executor ---
AIOPS_EXECUTOR_TIMEOUT_SECONDS=120
AIOPS_EXECUTOR_MAX_OUTPUT_BYTES=1048576

# --- WebAI ---
AIOPS_WEBAI_BASE_URL=http://open-webui:8080

# --- Docker executor ---
# GID do grupo docker no host. Obtenha com: stat -c "%g" /var/run/docker.sock
DOCKER_GID=999
