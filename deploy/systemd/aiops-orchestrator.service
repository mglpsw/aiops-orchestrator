[Unit]
Description=AIOps Orchestrator
Documentation=file:/opt/aiops-orchestrator/README.md
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/aiops-orchestrator
EnvironmentFile=/opt/aiops-orchestrator/.env
Environment=COMPOSE_PROJECT_NAME=aiops-orchestrator
ExecStart=docker compose -p aiops-orchestrator -f /opt/aiops-orchestrator/deploy/docker-compose.yml up aiops-orchestrator
ExecStop=docker compose -p aiops-orchestrator -f /opt/aiops-orchestrator/deploy/docker-compose.yml stop aiops-orchestrator
Restart=on-failure
RestartSec=10s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=aiops-orchestrator
TimeoutStartSec=60s
TimeoutStopSec=30s

[Install]
WantedBy=multi-user.target
