{
  "$defs": {
    "ChunkCoverageV2": {
      "additionalProperties": false,
      "properties": {
        "degradation_causes": {
          "items": {
            "$ref": "#/$defs/CoverageDegradationV2"
          },
          "title": "Degradation Causes",
          "type": "array"
        },
        "expected_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Expected Files",
          "type": "array"
        },
        "missing_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Missing Files",
          "type": "array"
        },
        "missing_must_review_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Missing Must Review Files",
          "type": "array"
        },
        "must_review_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Must Review Files",
          "type": "array"
        },
        "partially_reviewed_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Partially Reviewed Files",
          "type": "array"
        },
        "reviewed_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Reviewed Files",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/CoverageStateV2"
        }
      },
      "required": [
        "status",
        "expected_files",
        "reviewed_files",
        "partially_reviewed_files",
        "missing_files",
        "must_review_files",
        "missing_must_review_files",
        "degradation_causes"
      ],
      "title": "ChunkCoverageV2",
      "type": "object"
    },
    "ChunkFindingV2": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "$ref": "#/$defs/FindingConfidenceV2"
        },
        "contract_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
            "type": "string"
          },
          "title": "Contract Ids",
          "type": "array"
        },
        "disposition": {
          "$ref": "#/$defs/FindingDispositionV2"
        },
        "evidence": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Evidence",
          "type": "string"
        },
        "file_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "File Path",
          "type": "string"
        },
        "finding_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Finding Id",
          "type": "string"
        },
        "impact": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Impact",
          "type": "string"
        },
        "line_end": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Line End"
        },
        "line_start": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Line Start"
        },
        "severity": {
          "$ref": "#/$defs/FindingSeverityV2"
        },
        "title": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "severity",
        "title",
        "file_path",
        "line_start",
        "line_end",
        "evidence",
        "impact",
        "confidence",
        "contract_ids",
        "disposition"
      ],
      "title": "ChunkFindingV2",
      "type": "object"
    },
    "ChunkResponseErrorEnvelopeV2": {
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "maximum": 100,
          "minimum": 1,
          "title": "Attempt",
          "type": "integer"
        },
        "chunk_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Chunk Id",
          "type": "string"
        },
        "error": {
          "$ref": "#/$defs/SanitizedResponseErrorV2"
        },
        "finish_reason": {
          "$ref": "#/$defs/FinishReasonV2"
        },
        "head_sha": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Head Sha",
          "type": "string"
        },
        "model": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Model",
          "type": "string"
        },
        "payload_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Payload Sha256",
          "type": "string"
        },
        "provider": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Provider",
          "type": "string"
        },
        "request_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Request Id",
          "type": "string"
        },
        "response_received": {
          "title": "Response Received",
          "type": "boolean"
        },
        "response_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Response Sha256"
        },
        "run_id": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Run Id",
          "type": "string"
        },
        "schema_id": {
          "const": "agent-review.chunk-response-envelope.v2",
          "title": "Schema Id",
          "type": "string"
        },
        "schema_version": {
          "const": 2,
          "title": "Schema Version",
          "type": "integer"
        },
        "source": {
          "const": "agent-review-provider-response",
          "title": "Source",
          "type": "string"
        },
        "status": {
          "const": "error",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "source",
        "run_id",
        "chunk_id",
        "payload_sha256",
        "head_sha",
        "provider",
        "model",
        "attempt",
        "request_id",
        "finish_reason",
        "response_received",
        "response_sha256",
        "status",
        "error"
      ],
      "title": "ChunkResponseErrorEnvelopeV2",
      "type": "object"
    },
    "ChunkResponseSuccessEnvelopeV2": {
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "maximum": 100,
          "minimum": 1,
          "title": "Attempt",
          "type": "integer"
        },
        "chunk_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Chunk Id",
          "type": "string"
        },
        "finish_reason": {
          "$ref": "#/$defs/FinishReasonV2"
        },
        "head_sha": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Head Sha",
          "type": "string"
        },
        "model": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Model",
          "type": "string"
        },
        "payload_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Payload Sha256",
          "type": "string"
        },
        "provider": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Provider",
          "type": "string"
        },
        "request_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "title": "Request Id",
          "type": "string"
        },
        "response_received": {
          "title": "Response Received",
          "type": "boolean"
        },
        "response_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Response Sha256"
        },
        "result": {
          "$ref": "#/$defs/ChunkReviewResultV2"
        },
        "run_id": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Run Id",
          "type": "string"
        },
        "schema_id": {
          "const": "agent-review.chunk-response-envelope.v2",
          "title": "Schema Id",
          "type": "string"
        },
        "schema_version": {
          "const": 2,
          "title": "Schema Version",
          "type": "integer"
        },
        "source": {
          "const": "agent-review-provider-response",
          "title": "Source",
          "type": "string"
        },
        "status": {
          "const": "success",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "source",
        "run_id",
        "chunk_id",
        "payload_sha256",
        "head_sha",
        "provider",
        "model",
        "attempt",
        "request_id",
        "finish_reason",
        "response_received",
        "response_sha256",
        "status",
        "result"
      ],
      "title": "ChunkResponseSuccessEnvelopeV2",
      "type": "object"
    },
    "ChunkReviewResultV2": {
      "additionalProperties": false,
      "properties": {
        "coverage": {
          "$ref": "#/$defs/ChunkCoverageV2"
        },
        "findings": {
          "items": {
            "$ref": "#/$defs/ChunkFindingV2"
          },
          "title": "Findings",
          "type": "array"
        },
        "limitations": {
          "items": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "schema_id": {
          "const": "agent-review.chunk-response.v2",
          "title": "Schema Id",
          "type": "string"
        },
        "schema_version": {
          "const": 2,
          "title": "Schema Version",
          "type": "integer"
        },
        "summary": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "summary",
        "findings",
        "coverage",
        "limitations"
      ],
      "title": "ChunkReviewResultV2",
      "type": "object"
    },
    "CoverageDegradationReasonV2": {
      "enum": [
        "artifact_missing",
        "budget_exhausted",
        "transport_failure",
        "schema_failure",
        "model_uncertainty"
      ],
      "title": "CoverageDegradationReasonV2",
      "type": "string"
    },
    "CoverageDegradationV2": {
      "additionalProperties": false,
      "properties": {
        "affected_files": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "title": "Affected Files",
          "type": "array"
        },
        "detail": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/CoverageDegradationReasonV2"
        }
      },
      "required": [
        "reason_code",
        "affected_files",
        "detail"
      ],
      "title": "CoverageDegradationV2",
      "type": "object"
    },
    "CoverageStateV2": {
      "enum": [
        "complete",
        "partial",
        "degraded"
      ],
      "title": "CoverageStateV2",
      "type": "string"
    },
    "FindingConfidenceV2": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "title": "FindingConfidenceV2",
      "type": "string"
    },
    "FindingDispositionV2": {
      "enum": [
        "new",
        "confirmed",
        "fixed",
        "dismissed",
        "superseded",
        "stale"
      ],
      "title": "FindingDispositionV2",
      "type": "string"
    },
    "FindingSeverityV2": {
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ],
      "title": "FindingSeverityV2",
      "type": "string"
    },
    "FinishReasonV2": {
      "enum": [
        "stop",
        "length",
        "content_filter",
        "tool_call",
        "error",
        "unknown"
      ],
      "title": "FinishReasonV2",
      "type": "string"
    },
    "ResponseErrorReasonV2": {
      "enum": [
        "schema_failure",
        "transport_failure",
        "policy_failure",
        "model_uncertainty"
      ],
      "title": "ResponseErrorReasonV2",
      "type": "string"
    },
    "SanitizedResponseErrorV2": {
      "additionalProperties": false,
      "properties": {
        "reason_code": {
          "$ref": "#/$defs/ResponseErrorReasonV2"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "reason_code",
        "retryable"
      ],
      "title": "SanitizedResponseErrorV2",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Named root model used for stable validation and JSON Schema refs.",
  "discriminator": {
    "mapping": {
      "error": "#/$defs/ChunkResponseErrorEnvelopeV2",
      "success": "#/$defs/ChunkResponseSuccessEnvelopeV2"
    },
    "propertyName": "status"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/ChunkResponseSuccessEnvelopeV2"
    },
    {
      "$ref": "#/$defs/ChunkResponseErrorEnvelopeV2"
    }
  ],
  "title": "ChunkResponseEnvelopeV2"
}
